{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [
    "./tsconfig.json",
    "./tsconfig.build.json",
    "./vitest.config.ts",
    "./vitest.config.base.ts"
  ],
  "tasks": {
    "dev": {
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["lib/**", "dist/**", ".next/**"]
    },
    "@uniorgjs/orgx#build": {
      "dependsOn": ["^build"],
      "outputs": ["types/**"]
    },
    "lint": {
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "clean": {
      "cache": false
    }
  }
}
