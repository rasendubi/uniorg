{
  "name": "uniorg-root",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "turbo clean",
    "build": "turbo build",
    "dev": "turbo dev",
    "test": "vitest",
    "ci": "turbo lint build test",
    "version": "changeset version && pnpm install --frozen-lockfile=false",
